# ============================================
# SubTracker Frontend - Environment Variables
# ============================================
# For local development, copy this to .env.local
# For Render Static Site, set VITE_API_URL in Environment settings
# ============================================

# Backend API URL (include /api suffix)
# Local:      http://localhost:8080/api
# Production: https://subscription-tracker-backend-mk2p.onrender.com/api
VITE_API_URL=http://localhost:8080/api
